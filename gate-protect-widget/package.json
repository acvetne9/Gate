{
  "name": "gate-protect-widget",
  "version": "1.3.1",
  "description": "Gate widget for bot detection, content protection, and access control",
  "main": "dist/gate-widget.min.js",
  "module": "dist/gate-widget.esm.js",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:iife && npm run build:esm",
    "build:iife": "esbuild src/index.js --bundle --minify --target=es2015 --format=iife --global-name=GateProtect --outfile=dist/gate-widget.min.js",
    "build:esm": "esbuild src/index.js --bundle --minify --target=es2015 --format=esm --outfile=dist/gate-widget.esm.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acvetne/gate-protect-widget.git"
  },
  "keywords": [
    "gate",
    "bot-detection",
    "content-protection",
    "anti-scraping",
    "ai-bots",
    "gate",
    "security"
  ],
  "author": "Gate Securities LLC",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/acvetne/gate-protect-widget/issues"
  },
  "homepage": "https://github.com/acvetne/gate-protect-widget#readme",
  "devDependencies": {
    "esbuild": "^0.19.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "dotenv": "^17.2.3"
  }
}
